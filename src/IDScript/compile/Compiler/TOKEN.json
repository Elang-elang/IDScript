{
  "metadata": {
    "name": "IDScript Official Compiler Token Table",
    "version": 1,
    "encoding": "utf-8"
  },
  "file_formats": {
    "module": {
      "extension": ".idsm",
      "magic": "IDSM1\n",
      "description": "IDScript Module: hasil kompilasi tahap pertama yang masih deskriptif."
    },
    "compiled": {
      "extension": ".idsc",
      "magic": "IDSC1\n",
      "description": "IDScript Compiled: bytecode final untuk runtime VM."
    },
    "legacy": {
      "extension": ".idbc",
      "magic": "IDBC1\n",
      "description": "Format lama dari VMCompiler, hanya untuk kompatibilitas baca."
    }
  },
  "opcodes": {
    "LOAD_CONST": 1,
    "LOAD_DEFAULT": 2,
    "LOAD_NAME": 3,
    "STORE_NAME": 4,
    "STORE_FAST": 5,
    "POP_TOP": 6,
    "BINARY_OP": 7,
    "UNARY_OP": 8,
    "BOOL_AND": 9,
    "BOOL_OR": 10,
    "COMPARE_OP": 11,
    "JUMP_ABSOLUTE": 12,
    "POP_JUMP_IF_FALSE": 13,
    "CALL_FUNCTION": 14,
    "RETURN_VALUE": 15,
    "BUILD_LIST": 16,
    "BUILD_MAP": 17,
    "BINARY_SUBSCR": 18,
    "STORE_SUBSCR": 19,
    "GET_ITER": 20,
    "FOR_ITER": 21,
    "IMPORT_NAME": 22,
    "RAISE_ERROR": 23,
    "LOAD_ATTR": 24,
    "STORE_ATTR": 25,
    "BUILD_STRUCT_TYPE": 26,
    "BUILD_STRUCT_INSTANCE": 27,
    "STORE_FIELD": 28,
    "STORE_METHOD": 29,
    "MATCH_VALUE": 30,
    "SETUP_TRY": 31,
    "END_TRY": 32,
    "BUILD_ENUM_TYPE": 33,
    "BUILD_TYPE_ALIAS": 34,
    "BUILD_INTERFACE": 35,
    "LOAD_INFO": 36,
    "TO_BOOL": 37,
    "POP_JUMP_IF_TRUE": 38
  },
  "opcode_aliases": {
    "CONST": "LOAD_CONST",
    "DEFAULT": "LOAD_DEFAULT",
    "LOAD": "LOAD_NAME",
    "STORE": "STORE_NAME",
    "STORE_LOCAL": "STORE_FAST",
    "POP": "POP_TOP",
    "BINARY": "BINARY_OP",
    "UNARY": "UNARY_OP",
    "COMPARE": "COMPARE_OP",
    "JUMP": "JUMP_ABSOLUTE",
