    "MAKE_ENUM": "BUILD_ENUM_TYPE",
    "MAKE_TYPE_ALIAS": "BUILD_TYPE_ALIAS",
    "MAKE_INTERFACE": "BUILD_INTERFACE",
    "INFO": "LOAD_INFO"
