fungsi Tambah(*obj: Angka, sbj: Angka): Kosong {
    *obj = *obj + sbj;
}

fungsi utama(): Angka {
    var result: Angka;
    var angka_tambah: Angka = 15;
    Tambah(&result, angka_tambah);

    jika (result == angka_tambah) {
        println("Berhasil dengan nilai akhir: {}", result);
    } jika tidak {
        println("Gagal dengan nilai akhir: {}", result);
    }
    kembalikan result;

}