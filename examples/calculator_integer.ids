fungsi tambah(a: Angka, b: Angka): Angka {
    kembalikan a + b;
}

fungsi kurang(a: Angka, b: Angka): Angka {
    kembalikan a - b;
}

fungsi kali(a: Angka, b: Angka): Angka {
    kembalikan a * b;
}

fungsi pangkat(a: Angka, b: Angka): Angka {
    kembalikan a ** b;
}

fungsi utama(): Angka {
    var hasil: Angka = 0;
    hasil = tambah(20, 7);
    hasil = hasil + kurang(20, 7);
    hasil = hasil + kali(6, 4);
    hasil = hasil + pangkat(2, 5);
    println(hasil);
    kembalikan hasil;
}
