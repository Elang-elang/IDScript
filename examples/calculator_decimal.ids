fungsi rata_rata(a: Float, b: Float, c: Float): Float {
    kembalikan (a + b + c) / 3.0;
}

fungsi luas_lingkaran(radius: Float): Float {
    final pi: Float = 3.14159;
    kembalikan pi * radius ** 2.0;
}

fungsi utama(): Float {
    var hasil: Float = rata_rata(1.5, 2.5, 5.0);
    hasil = hasil + luas_lingkaran(2.0);
    println(hasil);
    kembalikan hasil;
}
